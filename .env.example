# Salin file ini menjadi ".env" lalu isi dengan data asli perusahaan.
# Semua variabel WAJIB diawali "NUXT_PUBLIC_" agar terbaca oleh Nuxt runtimeConfig.public
# (lihat nuxt.config.ts). Nilai ini akan tampil di sisi client, jadi jangan taruh secret/API key rahasia di sini.

# URL final website setelah live di Netlify (dipakai untuk SEO, sitemap, dan robots.txt)
NUXT_PUBLIC_SITE_URL=https://solusisistem.com

# Nama perusahaan yang tampil di footer, meta tag, dan JSON-LD
NUXT_PUBLIC_COMPANY_NAME="Solusi Sistem"

# Nomor WhatsApp tujuan untuk tombol chat & CTA.
# Format WAJIB: kode negara tanpa "+" dan tanpa spasi/strip. Contoh nomor 0812-3456-7890 -> 6281234567890
NUXT_PUBLIC_WHATSAPP_NUMBER=6281234567890

# Email bisnis yang tampil di halaman kontak & footer
NUXT_PUBLIC_EMAIL=hello@solusisistem.com

# Nomor telepon yang ditampilkan (boleh beda format dari nomor WhatsApp)
NUXT_PUBLIC_PHONE="+62 812-3456-7890"

# Alamat kantor/operasional (bebas format, tampil sebagai teks biasa)
NUXT_PUBLIC_ADDRESS="Jakarta, Indonesia"

# Link sosial media, kosongkan jika belum ada (ikon otomatis disembunyikan jika kosong)
NUXT_PUBLIC_INSTAGRAM_URL=
NUXT_PUBLIC_LINKEDIN_URL=
NUXT_PUBLIC_GITHUB_URL=

# Google Analytics Measurement ID, kosongkan jika belum pakai GA (format: G-XXXXXXXXXX)
NUXT_PUBLIC_GA_ID=

# Nama form Netlify Forms, biasanya tidak perlu diubah
NUXT_PUBLIC_CONTACT_FORM_NAME=contact
